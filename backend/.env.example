# PostgreSQL Connection String (e.g. Supabase, Neon, local Docker)
DATABASE_URL="postgresql://username:password@host:5432/database"

# WebAuthn Relying Party Configuration
# For local development, this should be "localhost"
RP_ID="localhost"
RP_NAME="Stack@CS Systems Demo"

# The origin of your frontend application
EXPECTED_ORIGIN="http://localhost:3000"

# Port for the Express server to listen on
PORT=4000
